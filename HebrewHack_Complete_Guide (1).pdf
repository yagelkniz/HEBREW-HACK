<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Learn Hebrew Online | HebrewHack</title>
<meta name="description" content="Live Zoom lessons with Israeli teachers. Speak Hebrew like a local from day one." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800;900&family=Caveat:wght@400;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
  html, body { margin: 0; padding: 0; overflow-x: hidden; max-width: 100%; }
  body { font-family: 'Rubik', system-ui, sans-serif; background: #FFF5E1; }
  *, *::before, *::after { box-sizing: border-box; }
  img, video { max-width: 100%; height: auto; }
  @keyframes scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @keyframes spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .6; transform: scale(1.3); } }
  @keyframes waPop { 0% { opacity: 0; transform: translateY(8px) scale(.85); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes waDot { 0%, 60%, 100% { transform: translateY(0); opacity: .4; } 30% { transform: translateY(-4px); opacity: 1; } }
  @keyframes stickerWiggle { 0%, 100% { transform: rotate(8deg) scale(1); } 50% { transform: rotate(-4deg) scale(1.06); } }
  @keyframes glow { 0%, 100% { box-shadow: 0 12px 40px rgba(0,0,0,.4), 0 0 0 0 rgba(255,107,157,.5); } 50% { box-shadow: 0 12px 40px rgba(0,0,0,.4), 0 0 0 18px rgba(255,107,157,0); } }
  .hh-typing-dots > span { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: .4; animation: waDot 1.2s ease-in-out infinite; }
  .hh-typing-dots > span:nth-child(2) { animation-delay: .15s; }
  .hh-typing-dots > span:nth-child(3) { animation-delay: .3s; }

  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .hh-root { width: 100% !important; max-width: 100vw !important; }
    .hh-h1 { font-size: 40px !important; }
    .hh-h2 { font-size: 30px !important; }
    .hh-hero { padding: 40px 18px 60px !important; }
    .hh-hero-inner { grid-template-columns: 1fr !important; gap: 40px !important; }
    .hh-hero-visual { min-height: 360px !important; }
    .hh-lead { font-size: 17px !important; max-width: 100% !important; }
    .hh-section { padding: 60px 18px !important; }
    .hh-grid-2 { grid-template-columns: 1fr !important; gap: 28px !important; }
    .hh-grid-3 { grid-template-columns: 1fr !important; gap: 18px !important; }
    .hh-grid-4 { grid-template-columns: 1fr 1fr !important; gap: 12px !important; }
    .hh-form { grid-template-columns: 1fr !important; }
    .hh-nav-links { display: none !important; }
    .hh-nav-inner { padding: 12px 16px !important; }
    .hh-signup-card { padding: 28px 20px !important; border-radius: 22px !important; }
    .hh-marquee-track { font-size: 16px !important; gap: 36px !important; }
    .hh-compare-row { font-size: 11px !important; padding: 10px 8px !important; }
    .hh-compare-row > * { padding: 4px !important; }
    .hh-stat-row { gap: 14px !important; flex-wrap: wrap; }
    .hh-btn { font-size: 16px !important; padding: 14px 20px !important; }
    .hh-submit { font-size: 16px !important; padding: 16px !important; }
    .hh-video-strip { grid-template-columns: 1fr 1fr !important; }
    .hh-lesson-card, .hh-chat-card { position: relative !important; inset: auto !important; width: 100% !important; left: 0 !important; transform: none !important; margin-bottom: 14px; }
    .hh-pdf-stamp { width: 70px !important; height: 70px !important; font-size: 16px !important; }
    .hh-teacher-photo-wrap { aspect-ratio: 1 / 1 !important; }
    .hh-sticker { width: 100px !important; font-size: 14px !important; }
    .hh-scribble { font-size: 22px !important; }
  }
</style>
<script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
<script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
<script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>
</head>
<body>
<div id="root"></div>

<script type="text/babel" src="variants/sunset-hack.jsx"></script>

<script type="text/babel">
  ReactDOM.createRoot(document.getElementById('root')).render(<window.SunsetHack />);
</script>
</body>
</html>
